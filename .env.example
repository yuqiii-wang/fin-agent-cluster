# ── Volcano Engine Doubao LLM ─────────────────────────────────
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-mini-260215

# ── LLM provider selection: ark | gemini | ollama ─────────────
LLM_PROVIDER=ollama

# -- Google Gemini (model list: https://ai.google.dev/gemini-api/docs/models)
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
GOOGLE_GEMINI_PROJECT_ID=

# ── Local LLM (Ollama OpenAI-compatible REST) ────────────────
OLLAMA_SERVER_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5-27b

# ── Financial Modeling Prep API ───────────────────────────────
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable/


# ---
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/fin_agents

# ── FastAPI ───────────────────────────────────────────────────
FASTAPI_PORT=8432

# ── Web search provider ───────────────────────────────────────
# Choices: auto | ddgs | bing | google | volc
# auto = try bing → google → volc → ddgs (first configured wins)
WEB_SEARCH_PROVIDER=auto

# Bing News Search API v7 (Azure Cognitive Services)
# https://www.microsoft.com/en-us/bing/apis/bing-news-search-api
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/news/search

# Google Custom Search API
# https://developers.google.com/custom-search/v1/introduction
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Volcano Engine web search
# https://www.volcengine.com/docs/6369/67269
VOLC_SEARCH_HOST=open.volcengineapi.com
VOLC_SEARCH_SERVICE=search_platform
VOLC_SEARCH_REGION=cn-north-1



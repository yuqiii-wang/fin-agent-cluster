# ── Volcano Engine Doubao LLM ─────────────────────────────────
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-mini-260215
LLM_PROVIDER=ark

# ── Local LLM (llama.cpp) ────────────────────────────────────
LLAMACPP_MODEL_PATH=
LLAMACPP_N_CTX=4096
LLAMACPP_N_GPU_LAYERS=-1

# ── Financial Modeling Prep API ───────────────────────────────
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable/

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/fin_agents

# ── FastAPI ───────────────────────────────────────────────────
FASTAPI_PORT=8432
{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "id": null,
  "uid": "fin-loki-logs",
  "title": "Fin Trading — Log Explorer",
  "description": "Search and filter structured application logs shipped by Promtail → Loki.",
  "tags": ["loki", "logs", "fin-trading"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,

  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Log File",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"fin-trading\"}, source)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"fin-trading\"}, level)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "value": "" },
        "query": ""
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Log Stream",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"fin-trading\", source=~\"$source\", level=~\"$level\"} |= \"$search\"",
          "queryType": "range",
          "maxLines": 500
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({job=\"fin-trading\", source=~\"$source\"}[1m]))",
          "queryType": "range",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log Rate by Log File",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (source) (rate({job=\"fin-trading\"}[1m]))",
          "queryType": "range",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errors (last 1 h)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"fin-trading\", level=\"ERROR\"}[1h]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Warnings (last 1 h)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"fin-trading\", level=\"WARNING\"}[1h]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Logs (last 1 h)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"fin-trading\"}[1h]))",
          "queryType": "instant"
        }
      ]
    }
  ]
}
